{
  "manifest_version": 3,
  "name": "http helper",
  "version": "2.3.0",
  "description": "在 Chrome DevTools 中捕获并展示 HTTP 请求与响应的原生报文",
  "permissions": ["storage"],
  "icons": {
    "16": "dist/icons/icon16.png",
    "32": "dist/icons/icon32.png",
    "48": "dist/icons/icon48.png",
    "128": "dist/icons/icon128.png"
  },
  "devtools_page": "dist/devtools.html",
  "web_accessible_resources": [
    {
      "resources": ["dist/panel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}