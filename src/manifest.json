{
  "manifest_version": 3,
  "name": "http helper",
  "version": "2.2.1",
  "description": "在 Chrome DevTools 中捕获并展示 HTTP 请求与响应的原生报文",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "devtools.html",
  "web_accessible_resources": [
    {
      "resources": ["panel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
